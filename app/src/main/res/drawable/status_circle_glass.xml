<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:endColor="#0022C55E"
                android:gradientRadius="140dp"
                android:startColor="#1A22C55E"
                android:type="radial" />
        </shape>
    </item>
    <!-- Glass Body -->
    <item
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp"
        android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <stroke
                android:width="1.5dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>