<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_slate"
    android:fitsSystemWindows="true">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Page Indicator (Dots) - Positioned above the button -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            app:tabBackground="@drawable/onboarding_dot_selector"
            app:tabIndicatorHeight="0dp"
            app:tabMaxWidth="12dp"
            app:tabRippleColor="@null" />

        <!-- Fixed 24dp margin between indicator and action buttons -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <!-- Primary button for general onboarding pages -->
            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/neon_green"
                android:text="@string/btn_next"
                android:textColor="@color/bg_dark_slate"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <!-- Specialized buttons for the Permissions screen, stacked in the same position -->
            <Button
                android:id="@+id/btnGrantPermissions"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/neon_green"
                android:text="@string/btn_grant_permissions"
                android:textColor="@color/bg_dark_slate"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/neon_green"
                android:text="@string/btn_continue"
                android:textColor="@color/bg_dark_slate"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>